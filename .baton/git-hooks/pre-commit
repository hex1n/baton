#!/usr/bin/env bash
# pre-commit — baton plan-first enforcement (git pre-commit hook)
# Blocks source code commits unless plan.md contains <!-- BATON:GO -->
# baton:pre-commit

# Emergency bypass
[ "${BATON_BYPASS:-}" = "1" ] && exit 0

# Check staged files: if all are markdown, allow
HAS_SOURCE=0
while IFS= read -r -d '' f; do
    case "$f" in
        *.md|*.MD|*.markdown|*.mdx) ;;
        *) HAS_SOURCE=1; break ;;
    esac
done < <(git diff --cached --name-only -z --diff-filter=ACM)
[ "$HAS_SOURCE" -eq 0 ] && exit 0

# Source shared functions (git runs pre-commit from repo root)
_COMMON_SH="$(pwd)/.baton/hooks/_common.sh"
if [ -f "$_COMMON_SH" ]; then
    . "$_COMMON_SH"
else
    echo "⚠️ baton: _common.sh not found, allowing commit (fail-open)" >&2
    exit 0
fi
resolve_plan_name
find_plan

# Check BATON:GO
if [ -z "$PLAN" ]; then
    echo "🔒 baton: No plan.md found. Create a plan before committing source code." >&2
    echo "   Bypass: BATON_BYPASS=1 git commit" >&2
    exit 1
fi

if ! grep -q '<!-- BATON:GO -->' "$PLAN" 2>/dev/null; then
    echo "🔒 baton: plan.md exists but not approved. Add <!-- BATON:GO --> first." >&2
    echo "   Bypass: BATON_BYPASS=1 git commit" >&2
    exit 1
fi

exit 0
