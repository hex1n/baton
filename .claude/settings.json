{
  "env": {
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "35",
    "BATON_PLAN": "baton-tasks/first-principles-analysis/plan.md"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|CreateFile|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".baton/hooks/run-hook.cmd PreToolUse"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".baton/hooks/run-hook.cmd PreToolUse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|CreateFile|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".baton/hooks/run-hook.cmd PostToolUse"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".baton/hooks/run-hook.cmd SessionStart"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".baton/hooks/run-hook.cmd Stop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".baton/hooks/run-hook.cmd PreCompact"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".baton/hooks/run-hook.cmd SubagentStart"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".baton/hooks/run-hook.cmd TaskCompleted"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".baton/hooks/run-hook.cmd PostToolUseFailure"
          }
        ]
      }
    ]
  }
}
