{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .baton/adapters/codex/dispatch.sh SessionStart",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .baton/adapters/codex/dispatch.sh Stop",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
