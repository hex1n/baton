#!/usr/bin/env bash
# baton — CLI entry point for baton plan-first workflow
# Version: 1.1
set -eu

BATON_HOME="${BATON_HOME:-$HOME/.baton}"
SETUP="$BATON_HOME/setup.sh"
REGISTRY="$BATON_HOME/projects.list"

# --- Registry management ---

registry_add() {
    _dir="$(cd "$1" && pwd)"
    touch "$REGISTRY"
    if grep -qxF "$_dir" "$REGISTRY" 2>/dev/null; then
        return 0
    fi
    echo "$_dir" >> "$REGISTRY"
}

registry_remove() {
    _dir="$(cd "$1" && pwd)" 2>/dev/null || _dir="$1"
    [ ! -f "$REGISTRY" ] && return 0
    _tmp="$REGISTRY.tmp"
    grep -vxF "$_dir" "$REGISTRY" > "$_tmp" 2>/dev/null || true
    mv "$_tmp" "$REGISTRY"
}

registry_list() {
    if [ ! -f "$REGISTRY" ] || [ ! -s "$REGISTRY" ]; then
        echo "No projects registered. Run 'baton init' in a project."
        return 0
    fi
    echo "Registered projects:"
    while IFS= read -r _dir; do
        [ -z "$_dir" ] && continue
        if [ -d "$_dir" ]; then
            _ver=""
            if [ -f "$_dir/.baton/hooks/write-lock.sh" ]; then
                _ver="$(sed -n 's/^# Version: *//p' "$_dir/.baton/hooks/write-lock.sh" 2>/dev/null)"
            fi
            _ides=""
            [ -d "$_dir/.claude" ]     && _ides="${_ides} claude"
            [ -d "$_dir/.factory" ]    && _ides="${_ides} factory"
            [ -d "$_dir/.cursor" ]     && _ides="${_ides} cursor"
            [ -f "$_dir/AGENTS.md" ]   && _ides="${_ides} codex"
            _ides="$(echo "$_ides" | sed 's/^ //')"
            printf "  %-50s v%-6s [%s]\n" "$_dir" "${_ver:-?}" "${_ides:-none}"
        else
            printf "  %-50s (not found)\n" "$_dir"
        fi
    done < "$REGISTRY"
}

# --- Doctor ---

doctor() {
    _dir="${1:-.}"
    _dir="$(cd "$_dir" && pwd)"
    _issues=0

    echo "Checking baton installation in $_dir..."
    echo ""

    # Scripts
    echo "  Scripts:"
    for _script in plan-parser.sh write-lock.sh phase-guide.sh stop-guard.sh bash-guard.sh \
                   post-write-tracker.sh subagent-context.sh completion-check.sh pre-compact.sh \
                   failure-tracker.sh; do
        if [ -f "$_dir/.baton/hooks/$_script" ]; then
            _pv="$(sed -n 's/^# Version: *//p' "$_dir/.baton/hooks/$_script" 2>/dev/null)"
            _sv=""
            if [ -f "$BATON_HOME/.baton/hooks/$_script" ]; then
                _sv="$(sed -n 's/^# Version: *//p' "$BATON_HOME/.baton/hooks/$_script" 2>/dev/null)"
            fi
            if [ -n "$_pv" ] && [ -n "$_sv" ] && [ "$_pv" != "$_sv" ]; then
                printf "  ⚠ %-20s v%s (latest: v%s)\n" "$_script" "$_pv" "$_sv"
                _issues=$((_issues + 1))
            else
                printf "  ✓ %-20s v%s\n" "$_script" "${_pv:-?}"
            fi
        else
            printf "  ✗ %-20s missing\n" "$_script"
            _issues=$((_issues + 1))
        fi
    done
    echo ""

    # IDE configs
    echo "  IDE configuration:"
    [ -d "$_dir/.claude" ]     && { _check_ide_config "$_dir" "claude" ".claude/settings.json" "baton"; }
    [ -d "$_dir/.factory" ]    && { _check_ide_config "$_dir" "factory" ".claude/settings.json" "baton"; }
    [ -d "$_dir/.cursor" ]     && { _check_ide_config "$_dir" "cursor" ".cursor/hooks.json" "baton"; }
    [ -f "$_dir/AGENTS.md" ]   && { _check_ide_config "$_dir" "codex" "AGENTS.md" "baton"; }
    echo ""

    # Adapters
    echo "  Adapters:"
    if [ -d "$_dir/.cursor" ]; then
        if [ -f "$_dir/.baton/adapters/adapter-cursor.sh" ] && [ -x "$_dir/.baton/adapters/adapter-cursor.sh" ] 2>/dev/null || [ -f "$_dir/.baton/adapters/adapter-cursor.sh" ]; then
            printf "  ✓ %-12s adapter-cursor.sh present\n" "cursor"
        else
            printf "  ✗ %-12s adapter-cursor.sh missing\n" "cursor"
            _issues=$((_issues + 1))
        fi
    fi
    if [ -f "$_dir/AGENTS.md" ]; then
        if [ -f "$_dir/.baton/adapters/adapter-codex.sh" ]; then
            printf "  ✓ %-12s adapter-codex.sh present\n" "codex"
        else
            printf "  ✗ %-12s adapter-codex.sh missing\n" "codex"
            _issues=$((_issues + 1))
        fi
    fi
    echo ""

    # Skills
    echo "  Skills:"
    _skill_dirs=""
    [ -d "$_dir/.claude/skills" ] && _skill_dirs="$_skill_dirs .claude/skills"
    [ -d "$_dir/.cursor/skills" ] && _skill_dirs="$_skill_dirs .cursor/skills"
    [ -d "$_dir/.agents/skills" ] && _skill_dirs="$_skill_dirs .agents/skills"
    for _sdir in $_skill_dirs; do
        _smissing=0
        for _skill in baton-plan baton-implement baton-review baton-research baton-debug baton-subagent; do
            if [ ! -f "$_dir/$_sdir/$_skill/SKILL.md" ]; then
                _smissing=$((_smissing + 1))
            fi
        done
        if [ "$_smissing" -eq 0 ]; then
            printf "  ✓ %-20s 6/6 skills present\n" "$_sdir"
        else
            printf "  ⚠ %-20s %s/6 skills missing\n" "$_sdir" "$_smissing"
            _issues=$((_issues + 1))
        fi
    done
    if [ -z "$_skill_dirs" ]; then
        echo "  ⚠ No skill directories found"
        _issues=$((_issues + 1))
    fi
    echo ""

    # Rules injection
    echo "  Rules injection:"
    if [ -f "$_dir/CLAUDE.md" ]; then
        if grep -qE '@\.baton/workflow\.md' "$_dir/CLAUDE.md" 2>/dev/null; then
            if grep -q '@\.baton/workflow-full\.md' "$_dir/CLAUDE.md" 2>/dev/null; then
                echo "  ⚠ CLAUDE.md contains residual @.baton/workflow-full.md import"
                _issues=$((_issues + 1))
            else
                echo "  ✓ CLAUDE.md contains @.baton/workflow.md"
            fi
        else
            echo "  ⚠ CLAUDE.md exists but no @.baton/workflow.md"
            _issues=$((_issues + 1))
        fi
    fi
    if [ -f "$_dir/AGENTS.md" ]; then
        if grep -q '@\.baton/workflow\.md' "$_dir/AGENTS.md"; then
            if grep -q '@\.baton/workflow-full\.md' "$_dir/AGENTS.md" 2>/dev/null; then
                echo "  ⚠ AGENTS.md contains residual @.baton/workflow-full.md import"
                _issues=$((_issues + 1))
            else
                echo "  ✓ Rules injection (AGENTS.md)"
            fi
        else
            echo "  ⚠ AGENTS.md exists but does not import @.baton/workflow.md"
            _issues=$((_issues + 1))
        fi
    fi
    echo ""

    if [ "$_issues" -gt 0 ]; then
        echo "  Result: $_issues issue(s) found. Run 'baton init' to auto-fix."
    else
        echo "  Result: all checks passed."
    fi
}

_check_ide_config() {
    _cdir="$1" _cide="$2" _cfile="$3" _cpattern="$4"
    if [ -f "$_cdir/$_cfile" ] && grep -q "$_cpattern" "$_cdir/$_cfile" 2>/dev/null; then
        printf "  ✓ %-12s hooks configured\n" "$_cide"
    elif [ -f "$_cdir/$_cfile" ]; then
        printf "  ⚠ %-12s config exists but no baton hooks\n" "$_cide"
    else
        printf "  ⚠ %-12s directory exists but no hook config\n" "$_cide"
    fi
}

# --- Status ---

status() {
    _dir="${1:-.}"
    _dir="$(cd "$_dir" && pwd)"

    # Source parser from target project or BATON_HOME
    _parser=""
    [ -f "$_dir/.baton/hooks/plan-parser.sh" ] && _parser="$_dir/.baton/hooks/plan-parser.sh"
    [ -z "$_parser" ] && [ -f "$BATON_HOME/.baton/hooks/plan-parser.sh" ] && _parser="$BATON_HOME/.baton/hooks/plan-parser.sh"
    if [ -z "$_parser" ]; then
        echo "⚠️ Parser not found in project or BATON_HOME" >&2
        return 1
    fi
    # Reset parser loaded guard so re-sourcing works for different projects
    _BATON_PARSER_LOADED=""
    . "$_parser"

    # Discovery — set JSON_CWD for both parser calls
    JSON_CWD="$_dir"
    parser_find_plan
    parser_find_research

    # Phase detection
    _phase="RESEARCH"
    _plan_status="not found"
    _research_status="not found"
    _todos="0/0"

    # Research status
    if [ -n "$RESEARCH" ]; then
        _research_status="exists"
    elif [ "${RESEARCH_FALLBACK_COUNT:-0}" -gt 1 ] 2>/dev/null; then
        _research_status="multiple matches"
        RESEARCH_NAME="research-*.md"
        echo "⚠️ Multiple research files found (research-*.md). Name your plan to match the primary research file, or consolidate." >&2
    fi

    # Phase from research
    if [ -z "$PLAN" ] && { [ -n "$RESEARCH" ] || [ "${RESEARCH_FALLBACK_COUNT:-0}" -gt 1 ] 2>/dev/null; }; then
        _phase="PLAN"
    fi

    # Plan-based phase
    if [ -n "$PLAN" ]; then
        _plan_status="exists, no BATON:GO"
        _phase="ANNOTATION"

        if parser_has_go; then
            _plan_status="approved (BATON:GO)"
            _phase="IMPLEMENT"

            parser_todo_counts
            _todos="$TODO_DONE/$TODO_TOTAL"

            if [ "$TODO_TOTAL" -gt 0 ] && [ "$TODO_REMAINING" -eq 0 ]; then
                _phase="FINISH"
                if parser_retro_valid; then
                    _finish_status="ready to complete"
                else
                    _finish_status="retrospective needed"
                fi
            fi

            parser_todo_range
            if [ "${TODO_START:-0}" -eq 0 ] 2>/dev/null || [ "$TODO_TOTAL" -eq 0 ] 2>/dev/null; then
                _phase="AWAITING_TODO"
            fi
        fi
    fi

    echo "📍 Phase: $_phase"
    echo "   Plan:     $PLAN_NAME ($_plan_status)"
    echo "   Research: $RESEARCH_NAME ($_research_status)"
    echo "   Todos:    $_todos"
    if [ "$_phase" = "FINISH" ]; then
        echo "   Finish:   $_finish_status"
    fi
}

# --- Usage ---

usage() {
    cat << 'EOF'
baton — plan-first workflow for AI coding assistants

Usage:
  baton init [dir]         Install baton into a project
  baton update [dir]       Update baton in a project
  baton update --all       Update all registered projects
  baton uninstall [dir]    Remove baton from a project
  baton self-update        Update baton itself
  baton list               List registered projects
  baton doctor [dir]       Check installation health
  baton status [dir]       Show workflow phase and progress
  baton help               Show this help

Environment:
  BATON_HOME               Override baton home directory (~/.baton)
  BATON_PLAN               Override plan filename
  BATON_BYPASS=1           Skip write-lock check
  BATON_SKIP=hook1,hook2   Skip specific hooks during install
EOF
}

# --- Main ---

case "${1:-help}" in
    init)
        _target="${2:-.}"
        if [ ! -d "$_target" ]; then
            echo "Error: $_target is not a directory" >&2
            exit 1
        fi
        bash "$SETUP" "$_target" && registry_add "$_target"
        ;;
    update)
        if [ "${2:-}" = "--all" ]; then
            if [ ! -f "$REGISTRY" ] || [ ! -s "$REGISTRY" ]; then
                echo "No projects registered. Run 'baton init' first."
                exit 0
            fi
            while IFS= read -r _dir; do
                [ -z "$_dir" ] && continue
                if [ -d "$_dir" ]; then
                    echo "=== Updating: $_dir ==="
                    bash "$SETUP" "$_dir"
                    echo ""
                else
                    echo "=== Skipping: $_dir (not found) ==="
                fi
            done < "$REGISTRY"
        else
            _target="${2:-.}"
            bash "$SETUP" "$_target"
        fi
        ;;
    uninstall)
        _target="${2:-.}"
        bash "$SETUP" --uninstall "$_target" && registry_remove "$_target"
        ;;
    self-update)
        echo "Updating baton..."
        if git -C "$BATON_HOME" pull --ff-only; then
            echo "✓ Updated to latest"
        else
            echo "⚠ Update failed. Check for local changes in $BATON_HOME"
            exit 1
        fi
        ;;
    list)
        registry_list
        ;;
    doctor)
        doctor "${2:-.}"
        ;;
    status)
        status "${2:-.}"
        ;;
    help|--help|-h|*)
        usage
        ;;
esac
